{
  "name": "lm-voice-app",
  "version": "0.1.0",
  "private": true,
  "description": "Voice companion for Claude Code sessions: mic → Anthropic STT → lm-assist Haiku agent → Supertonic TTS",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "start:debug": "electron . --enable-logging --remote-debugging-port=9223",
    "build:win": "electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "node-global-key-listener": "^0.3.0",
    "onnxruntime-node": "^1.20.0",
    "tesseract.js": "^7.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.langmart.lm-voice",
    "productName": "LM Voice",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/onnx",
      "!assets/voice_styles",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
